{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/ad-engine", "destination": "/ad-engine.html" },
    { "source": "/markdown", "destination": "https://pulsepro-markdown-preview.vercel.app/markdown" },
    { "source": "/markdown/:path*", "destination": "https://pulsepro-markdown-preview.vercel.app/markdown/:path*" }
  ]
}
