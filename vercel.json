{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/ad-engine", "destination": "/ad-engine.html" },
    { "source": "/rhythm-rescue", "destination": "/rhythm-rescue.html" },
    { "source": "/pitch", "destination": "/pitch/index.html" },
    { "source": "/game-breakdown", "destination": "/docs/game-breakdown.html" },
    { "source": "/markdown", "destination": "https://pulsepro-markdown-preview.vercel.app/markdown" },
    { "source": "/markdown/:path*", "destination": "https://pulsepro-markdown-preview.vercel.app/markdown/:path*" }
  ]
}
