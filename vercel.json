{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/whopaysfirst/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/biz101/:path*",
      "has": [{ "type": "host", "value": "(www\\.)?fonz\\.sh" }],
      "destination": "https://whopaysfirst.com",
      "permanent": true
    },
    {
      "source": "/whopaysfirst/:path*",
      "has": [{ "type": "host", "value": "(www\\.)?fonz\\.sh" }],
      "destination": "https://whopaysfirst.com",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ad-engine",
      "destination": "/ad-engine.html"
    },
    {
      "source": "/rhythm-rescue",
      "destination": "/rhythm-rescue.html"
    },
    {
      "source": "/pitch",
      "destination": "/pitch/index.html"
    },
    {
      "source": "/game-breakdown",
      "destination": "/docs/game-breakdown.html"
    },
    {
      "source": "/team",
      "destination": "/docs/team-explainer.html"
    },
    {
      "source": "/stages",
      "destination": "/docs/stage-mockups.html"
    },
    {
      "source": "/markdown",
      "destination": "https://pulsepro-markdown-preview.vercel.app/markdown"
    },
    {
      "source": "/markdown/:path*",
      "destination": "https://pulsepro-markdown-preview.vercel.app/markdown/:path*"
    }
  ]
}